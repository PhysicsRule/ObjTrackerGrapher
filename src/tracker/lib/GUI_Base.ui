  <property name="styleSheet">
   <string notr="true">
QWidget { background-color: #ffffff; color: #1a3a5c; }
QGroupBox {
    border: 2px solid #1a3a5c; border-radius: 4px;
    margin-top: 26px; background-color: #f0f6ff;
}
QGroupBox::title {
    subcontrol-origin: margin; subcontrol-position: top left;
    left: 8px; top: 0px; padding: 4px 10px;
    background-color: #1a3a5c; color: #ffffff;
    font-size: 9pt; font-weight: bold; border-radius: 3px;
}
QPushButton {
    background-color: #f0f4f8; color: #1a3a5c;
    border: 1px solid #1a3a5c; border-radius: 3px; padding: 3px 6px;
}
QPushButton:hover { background-color: #dae6f0; }
QPushButton:pressed { background-color: #1a3a5c; color: #ffffff; }
QLineEdit {
    background-color: #ffffff; color: #1a3a5c;
    border: 1px solid #7a9cbf; border-radius: 3px; padding: 2px 4px;
}
QLineEdit#folder_name {
    border: 2px solid #1a3a5c; background-color: #eef4fb;
    font-size: 9pt; padding: 4px;
}
QComboBox {
    background-color: #ffffff; color: #1a3a5c;
    border: 1px solid #7a9cbf; border-radius: 3px; padding: 2px 4px;
}
QComboBox::drop-down { border: none; }
QComboBox QAbstractItemView {
    background-color: #ffffff; color: #1a3a5c;
    selection-background-color: #1a3a5c; selection-color: #ffffff;
}
QTableWidget {
    background-color: #ffffff; alternate-background-color: #f0f4f8;
    gridline-color: #b0c4d8; color: #1a3a5c;
}
QHeaderView::section {
    background-color: #1a3a5c; color: #ffffff;
    border: 1px solid #0d2b4e; font-weight: bold;
}
QTableCornerButton::section { background-color: #1a3a5c; }
QListWidget {
    background-color: #ffffff; color: #1a3a5c;
    border: 1px solid #7a9cbf; border-radius: 3px;
}
QListWidget::item:selected { background-color: #1a3a5c; color: #ffffff; }
QCheckBox { color: #1a3a5c; spacing: 5px; }
QCheckBox::indicator {
    width: 13px; height: 13px;
    border: 1px solid #7a9cbf; border-radius: 2px; background-color: #ffffff;
}
QCheckBox::indicator:checked { background-color: #1a3a5c; border-color: #1a3a5c; }
QRadioButton { color: #1a3a5c; spacing: 5px; }
QRadioButton::indicator {
    width: 12px; height: 12px; border-radius: 6px;
    border: 1px solid #7a9cbf; background-color: #ffffff;
}
QRadioButton::indicator:checked { background-color: #1a3a5c; border-color: #1a3a5c; }
QLabel { color: #1a3a5c; }
QScrollArea { border: none; }
QScrollBar:vertical { background-color: #f0f4f8; width: 10px; margin: 0px; }
QScrollBar::handle:vertical { background-color: #7a9cbf; border-radius: 5px; min-height: 30px; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0px; border: none; }
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical { background: none; }
QStatusBar { color: #5a7a9c; }
   </string>
